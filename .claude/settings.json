{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \".\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if ! git rev-parse --git-dir >/dev/null 2>&1; then echo 'Not a git repo, skipping'; elif command -v code-review-graph >/dev/null 2>&1; then code-review-graph status --repo \".\" || true; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
